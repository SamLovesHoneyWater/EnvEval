{
  "repo": "NeMo_Gym",
  "tests": [
    {
      "id": "check_python_uv_tools",
      "type": "commands_exist",
      "params": {
        "names": [
          "python3",
          "pip3",
          "uv",
          "git",
          "curl"
        ]
      },
      "score": 2
    },
    {
      "id": "check_python_version_file",
      "type": "file_contains",
      "params": {
        "path": ".python-version",
        "contains": [
          "3.12"
        ]
      },
      "score": 1
    },
    {
      "id": "check_python_project_files",
      "type": "files_exist",
      "params": {
        "paths": [
          "pyproject.toml",
          "uv.lock",
          "README.md"
        ]
      },
      "score": 1
    },
    {
      "id": "check_repo_dirs",
      "type": "dirs_exist",
      "params": {
        "paths": [
          "nemo_gym",
          "resources_servers",
          "tests",
          "scripts"
        ]
      },
      "score": 1
    },
    {
      "id": "check_pyproject_contains_ray",
      "type": "file_contains",
      "params": {
        "path": "pyproject.toml",
        "contains": [
          "requires-python = \">=3.12\"",
          "ray[default]",
          "pytest"
        ]
      },
      "score": 1
    },
    {
      "id": "check_python_version",
      "type": "output_contains",
      "params": {
        "command": "python3 --version",
        "contains": [
          "3.12"
        ]
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_python_uv_tools"
      ]
    },
    {
      "id": "test_uv_version",
      "type": "run_command",
      "params": {
        "command": "uv --version"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_python_uv_tools"
      ]
    },
    {
      "id": "test_uv_sync_help",
      "type": "run_command",
      "params": {
        "command": "uv sync --help >/dev/null"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_python_uv_tools"
      ]
    },
    {
      "id": "test_unit_test_prereq",
      "type": "run_command",
      "params": {
        "command": "python3 -m pip --version"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_python_uv_tools"
      ]
    }
  ]
}
