{
  "repo": "SVRTK_svrtk-docker-gpu",
  "tests": [
    {
      "id": "check_system_tools",
      "type": "commands_exist",
      "params": {
        "names": ["git", "wget", "curl", "bash", "tar", "unzip"]
      },
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_build_tools",
      "type": "commands_exist",
      "params": {
        "names": ["gcc", "g++", "make", "cmake"]
      },
      "score": 3,
      "category": "configuration"
    },
    {
      "id": "check_python_tools",
      "type": "commands_exist",
      "params": {
        "names": ["python", "pip"]
      },
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_gpu_tools",
      "type": "commands_exist",
      "params": {
        "names": ["nvcc"]
      },
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_cuda_version",
      "type": "output_contains",
      "params": {
        "command": "nvcc --version 2>&1",
        "contains": ["release 11"]
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_cuda_version_acceptable_fallback",
      "type": "output_contains",
      "params": {
        "command": "nvcc --version 2>&1",
        "contains": ["release 11", "release 12"]
      },
      "timeout": 10,
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_boost_lib",
      "type": "run_command",
      "params": {
        "command": "(dpkg -s libboost-all-dev 2>/dev/null | grep -q 'Status: install ok installed') || (ldconfig -p | grep -qi libboost_system)"
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_eigen3",
      "type": "run_command",
      "params": {
        "command": "(dpkg -s libeigen3-dev 2>/dev/null | grep -q 'install ok installed') || [ -d /usr/include/eigen3 ] || [ -d /usr/local/include/eigen3 ]"
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_tbb",
      "type": "run_command",
      "params": {
        "command": "(dpkg -s libtbb-dev 2>/dev/null | grep -q 'install ok installed') || (ldconfig -p | grep -qi libtbb)"
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_fltk",
      "type": "run_command",
      "params": {
        "command": "(dpkg -s libfltk1.3-dev 2>/dev/null | grep -q 'install ok installed') || (ldconfig -p | grep -qi libfltk)"
      },
      "timeout": 10,
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_zlib_and_libpng",
      "type": "run_command",
      "params": {
        "command": "(dpkg -s zlib1g-dev libpng-dev 2>/dev/null | grep -q 'Status: install ok installed') || (ldconfig -p | grep -E -q 'libz\\.|libpng')"
      },
      "timeout": 10,
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_vtk_library",
      "type": "run_command",
      "params": {
        "command": "(dpkg -l 2>/dev/null | grep -qi libvtk) || (ldconfig -p | grep -qi libvtk) || (find /usr/local /usr/lib /opt -maxdepth 5 -name 'libvtk*' 2>/dev/null | grep -q libvtk)"
      },
      "timeout": 15,
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_dcmtk",
      "type": "commands_exist",
      "params": {
        "names": ["dcmtk"]
      },
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_dcm2niix_binary",
      "type": "run_command",
      "params": {
        "command": "command -v dcm2niix"
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_pigz",
      "type": "commands_exist",
      "params": {
        "names": ["pigz"]
      },
      "score": 1,
      "category": "configuration"
    },
    {
      "id": "check_torch_import",
      "type": "run_command",
      "params": {
        "command": "python -c \"import torch; print(torch.__version__)\" || python3 -c \"import torch; print(torch.__version__)\""
      },
      "timeout": 30,
      "score": 3,
      "category": "configuration"
    },
    {
      "id": "check_fetal_mri_python_deps",
      "type": "run_command",
      "params": {
        "command": "(python -c \"import nibabel, SimpleITK, torchio\" 2>/dev/null) || (python3 -c \"import nibabel, SimpleITK, torchio\")"
      },
      "timeout": 30,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_path_has_mirtk_or_build",
      "type": "output_contains",
      "params": {
        "command": "echo \"$PATH\"",
        "contains": ["MIRTK", "mirtk", "dcm2niix"]
      },
      "timeout": 10,
      "score": 2,
      "category": "configuration"
    },
    {
      "id": "check_root_files",
      "type": "files_exist",
      "params": {
        "paths": [
          "README.md",
          "svrtk-docker-gpu.Dockerfile",
          ".gitmodules"
        ]
      },
      "score": 2,
      "category": "structure"
    },
    {
      "id": "check_main_directories",
      "type": "dirs_exist",
      "params": {
        "paths": [
          "scripts",
          "recon"
        ]
      },
      "score": 2,
      "category": "structure"
    },
    {
      "id": "check_scripts_present",
      "type": "files_exist",
      "params": {
        "paths": [
          "scripts/docker-recon-brain-auto.bash",
          "scripts/StartSVR.bash",
          "scripts/svr_dcm2nii.bash",
          "scripts/reconDirClean.bash"
        ]
      },
      "score": 3,
      "category": "structure"
    },
    {
      "id": "check_dockerfile_contents",
      "type": "file_contains",
      "params": {
        "path": "svrtk-docker-gpu.Dockerfile",
        "contains": ["pytorch/pytorch", "MIRTK", "SVRTK", "dcm2niix"]
      },
      "score": 2,
      "category": "structure"
    },
    {
      "id": "check_gitmodules_entries",
      "type": "file_contains",
      "params": {
        "path": ".gitmodules",
        "contains": ["MIRTK", "SVRTK", "Segmentation_FetalMRI"]
      },
      "score": 2,
      "category": "structure"
    },
    {
      "id": "test_python_execution",
      "type": "run_command",
      "params": {
        "command": "(python -c \"print('Python works')\") || (python3 -c \"print('Python works')\")"
      },
      "timeout": 10,
      "score": 1,
      "category": "functionality"
    },
    {
      "id": "test_gcc_compiles",
      "type": "run_command",
      "params": {
        "command": "echo '#include <stdio.h>\nint main(){printf(\"ok\\n\");return 0;}' > /tmp/t.c && gcc -o /tmp/t /tmp/t.c && /tmp/t && rm -f /tmp/t /tmp/t.c"
      },
      "timeout": 30,
      "score": 2,
      "category": "functionality"
    },
    {
      "id": "test_cpp_compiles",
      "type": "run_command",
      "params": {
        "command": "echo '#include <iostream>\nint main(){std::cout<<\"cpp-ok\"<<std::endl;return 0;}' > /tmp/t.cpp && g++ -o /tmp/t /tmp/t.cpp && /tmp/t && rm -f /tmp/t /tmp/t.cpp"
      },
      "timeout": 30,
      "score": 2,
      "category": "functionality"
    },
    {
      "id": "test_cmake_help",
      "type": "run_command",
      "params": {
        "command": "cmake --version && cmake --help >/dev/null"
      },
      "timeout": 30,
      "score": 1,
      "category": "functionality"
    },
    {
      "id": "test_dcm2niix_invocation",
      "type": "run_command",
      "params": {
        "command": "dcm2niix -h 2>&1 | head -n 5"
      },
      "timeout": 30,
      "score": 3,
      "category": "functionality"
    },
    {
      "id": "test_mirtk_invocation",
      "type": "run_command",
      "params": {
        "command": "mirtk 2>&1 | head -n 20"
      },
      "timeout": 30,
      "score": 5,
      "category": "functionality"
    },
    {
      "id": "test_mirtk_lists_svrtk_module",
      "type": "output_contains",
      "params": {
        "command": "mirtk help-commands 2>&1 || mirtk 2>&1",
        "contains": ["reconstruct", "reconstructFFD", "prepare-for-cnn"]
      },
      "timeout": 30,
      "score": 4,
      "category": "functionality"
    },
    {
      "id": "test_scripts_executable",
      "type": "run_command",
      "params": {
        "command": "[ -x /home/scripts/docker-recon-brain-auto.bash ] || [ -x scripts/docker-recon-brain-auto.bash ]"
      },
      "timeout": 10,
      "score": 2,
      "category": "functionality"
    },
    {
      "id": "test_torch_cuda_flag_reported",
      "type": "run_command",
      "params": {
        "command": "(python -c \"import torch; print('compiled_with_cuda=', torch.backends.cuda.is_built())\") || (python3 -c \"import torch; print('compiled_with_cuda=', torch.backends.cuda.is_built())\")"
      },
      "timeout": 30,
      "score": 2,
      "category": "functionality"
    }
  ]
}
