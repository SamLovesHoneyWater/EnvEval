{
  "repo": "tao_tutorials",
  "tests": [
    {
      "id": "check_cli_tools",
      "type": "commands_exist",
      "params": {
        "names": [
          "python3",
          "pip3",
          "docker",
          "git"
        ]
      },
      "score": 2
    },
    {
      "id": "check_notebook_support",
      "type": "commands_exist",
      "params": {
        "names": [
          "jupyter"
        ]
      },
      "score": 1
    },
    {
      "id": "check_nvidia_docker",
      "type": "commands_exist",
      "params": {
        "names": [
          "nvidia-docker"
        ]
      },
      "score": 2
    },
    {
      "id": "check_repo_dirs",
      "type": "dirs_exist",
      "params": {
        "paths": [
          "notebooks",
          "setup"
        ]
      },
      "score": 1
    },
    {
      "id": "check_setup_files",
      "type": "files_exist",
      "params": {
        "paths": [
          "README.md",
          "setup/quickstart_launcher.sh"
        ]
      },
      "score": 1
    },
    {
      "id": "check_quickstart_contains_tao_install",
      "type": "file_contains",
      "params": {
        "path": "setup/quickstart_launcher.sh",
        "contains": [
          "pip3 install nvidia-tao",
          "pip3 install jupyter",
          "docker login"
        ]
      },
      "score": 1
    },
    {
      "id": "check_python_version",
      "type": "output_contains",
      "params": {
        "command": "python3 --version",
        "contains": [
          "Python 3"
        ]
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_cli_tools"
      ]
    },
    {
      "id": "test_pip_version",
      "type": "run_command",
      "params": {
        "command": "python3 -m pip --version"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_cli_tools"
      ]
    },
    {
      "id": "test_docker_version",
      "type": "run_command",
      "params": {
        "command": "docker --version"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_cli_tools"
      ]
    },
    {
      "id": "test_jupyter_version",
      "type": "run_command",
      "params": {
        "command": "jupyter --version"
      },
      "timeout": 10,
      "score": 1,
      "requires": [
        "check_notebook_support"
      ]
    },
    {
      "id": "test_tao_install_command",
      "type": "run_command",
      "params": {
        "command": "bash setup/quickstart_launcher.sh --help"
      },
      "timeout": 30,
      "score": 2,
      "requires": [
        "check_cli_tools"
      ]
    }
  ]
}
